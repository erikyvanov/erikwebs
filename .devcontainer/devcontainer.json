{
  "name": "Erik Webs",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "astro",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [4321, 2368],
  "shutdownAction": "stopCompose",
  "postCreateCommand": "pnpm install && git config --global --get user.name >/dev/null 2>&1 || echo '⚠️ Git user no configurado — ejecuta: git config --global user.name \"Tu Nombre\" && git config --global user.email \"tu@email.com\"'",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readOnly"
  ],
  "remoteEnv": {
    "GIT_SSH_COMMAND": "ssh -o StrictHostKeyChecking=accept-new",
    "DEEPSEEK_API_KEY": "${localEnv:DEEPSEEK_API_KEY}",
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "${localEnv:DEEPSEEK_API_KEY}",
    "ANTHROPIC_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-flash",
    "CLAUDE_CODE_SUBAGENT_MODEL": "deepseek-v4-flash",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK": "1"
  }
}
